# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
# Google Play service account JSON used by `eas submit -p android`. Materialized
# from EAS file secret EXPO_GOOGLE_SERVICE_ACCOUNT_KEY at submit time; must
# never be committed even if a local operator runs `eas credentials` and writes
# the file to the project root. No `*.json` rule exists above (intentionally —
# package.json/app.json/tsconfig.json are tracked), so an explicit line is the
# only safe defense for this specific filename.
google-service-account.json

# Backup files (e.g., editor-generated foo.md.bak from accidental rename)
*.bak

# Story 15-6: jest --coverage output (lcov + HTML report). Generated by the
# `Tests with coverage threshold` CI step; never tracked in source.
# R1 BH-5: anchored to repo root via leading `/` so a future sub-directory
# legitimately named `coverage` (e.g., `docs/insurance-coverage/`) is not
# silently dropped.
/coverage/

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

.history
.playwright-mcp

# Supabase CLI temp files
supabase/.temp/

# _bmad/ is tooling state — ignore entirely.
_bmad/
# _bmad-output/ contains tooling outputs that are mostly disposable, but
# implementation-artifacts (story files, sprint-status) and planning-artifacts
# (epics, roadmaps, runbooks) are checked-in source of truth. Story 9-9 (AC #9)
# narrowed the prior `_bmad*` blanket rule that was silently dropping new
# story files written by the create-story workflow.
_bmad-output/*
!_bmad-output/implementation-artifacts/
!_bmad-output/planning-artifacts/
.claude/skills

# Default: contents of docs/ are ignored (auto-generated by tooling).
# Use docs/* (not docs) so the directory is still walked and the exceptions
# below can re-include specific files; "docs" alone would ignore the whole
# subtree and exceptions would not fire.
docs/*
# Exceptions: tracked docs that must travel with the repo (citation chain
# referenced from CLAUDE.md, src/lib/constants.ts, and tcf-spec.test.ts).
!docs/tcf-spec-source.md
!docs/tcf-spec-source.pdf
# Story 10-1 — TCF Canada source snapshots used by tcf-spec-source.md citations.
!docs/tcf-canada-snapshots/
!docs/tcf-spec-citations.md