# ─── CLIENT-SIDE VARIABLES ───────────────────────────────────────────────────
# These are bundled into the app binary (intentionally public).
# Copy this file to .env.local and fill in your values.

# Supabase — the anon key is safe to expose; RLS protects all data
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sentry — error monitoring (create a project at sentry.io to get this)
# Never paste the DSN into app.json — keep it env-only.
EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# ─── SERVER-SIDE SECRETS (Supabase Edge Function secrets) ────────────────────
# These are NEVER added to .env.local or bundled into the app.
# Set them with: supabase secrets set KEY=value
#
#   OPENAI_API_KEY=sk-...
#   AZURE_SPEECH_KEY=your-azure-speech-key
#   AZURE_SPEECH_REGION=westeurope
# ─────────────────────────────────────────────────────────────────────────────
